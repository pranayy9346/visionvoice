# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/visionvoice

# AI Services
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
MURF_API_KEY=your_murf_api_key
MURF_VOICE_ID=en-US-natalie

# Upload & Performance
MAX_IMAGE_BYTES=6291456

# CORS & Security
FRONTEND_ORIGIN=http://localhost:5173

# Production: Set to your actual frontend domain
# Example: FRONTEND_ORIGIN=https://app.yourdomain.com
# For multiple origins: FRONTEND_ORIGIN=https://app.yourdomain.com,https://www.yourdomain.com
